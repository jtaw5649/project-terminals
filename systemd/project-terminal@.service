[Unit]
Description=Project terminal server %i
PartOf=graphical-session.target
After=graphical-session.target

[Service]
Type=exec
RuntimeDirectory=project-terminals/%i
RuntimeDirectoryMode=0700
ExecStartPre=%h/.local/bin/project-terminals service-start %i
ExecStart=/usr/bin/tmux -D -S %t/project-terminals/%i/tmux.sock -f %E/project-terminals/tmux.conf
ExecStop=%h/.local/bin/project-terminals service-stop %i
KillMode=control-group
TimeoutStopSec=10s
